PORT=4000
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@budget_ai_pg:5432/budget_ai_assistant
#DATABASE_URL=postgres://postgres:Lookup%40123@localhost:5432/budget_ai_assistant  
#local database
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=1d
CORS_ORIGIN=http://localhost:5173,https://budget-ai-assistant.vercel.app

USE_OPENAI_EMBEDDINGS=false
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# AWS S3
AWS_BUCKET=lovablepdfbucket

# Frontend URL — used in password reset email links (no trailing slash)
FRONTEND_URL=https://budget-ai-assistant.vercel.app/