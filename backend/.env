PORT=4000
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@budget_ai_pg:5432/budget_ai_assistant
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=1d
CORS_ORIGIN=http://50.16.113.181/

# OpenAI — required for LLM chat responses; embeddings optional
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini
USE_OPENAI_EMBEDDINGS=false
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# AWS S3 — required for file uploads
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_BUCKET=your-s3-bucket-name
AWS_REGION=us-east-1

# Frontend URL — used in password reset email links (no trailing slash)
FRONTEND_URL=http://50.16.113.181/