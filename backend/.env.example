PORT=4000
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/budget_ai_assistant
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=1d
# Comma-separated list of allowed frontend origins (no trailing slashes)
# Development:
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# Production (set this in your server .env):
# CORS_ORIGIN=https://budget-ai-assistant.vercel.app,https://budgetaiassistance.myaisquad.com

# OpenAI — required for LLM chat responses; embeddings optional
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini
USE_OPENAI_EMBEDDINGS=false
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# AWS S3 — required for file uploads
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_BUCKET=your-s3-bucket-name
AWS_REGION=us-east-1

# Frontend URL — used in password reset email links (no trailing slash)
FRONTEND_URL=http://localhost:5173
