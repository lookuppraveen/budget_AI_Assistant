PORT=4000
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/budget_ai_assistant
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=1d
CORS_ORIGIN=http://127.0.0.1:5173

# OpenAI — required for LLM chat responses; embeddings optional
OPENAI_API_KEY=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
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
USE_OPENAI_EMBEDDINGS=false
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# AWS S3 — required for file uploads
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_BUCKET=your-s3-bucket-name
AWS_REGION=us-east-1

# Frontend URL — used in password reset email links (no trailing slash)
FRONTEND_URL=http://localhost:5173

# Email Responder — two-way email interface (users email the Budget Agent and get AI replies)
# Set to false to disable the polling loop entirely
EMAIL_RESPONDER_ENABLED=true
# How often (ms) to poll the inbox for new emails — default 5 minutes (300000 ms)
EMAIL_RESPONDER_INTERVAL_MS=300000
